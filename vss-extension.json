{
    "manifestVersion": 1,
    "id": "azure-devops-extensions-accessEpics",
    "version": "1.1.8",
    "name": "AccessEpics",
    "description": "This is an example for how the real query can work",
    "publisher": "DiegoNttdata",
    "categories": ["Azure Boards"],
    "targets": [
        { "id": "Microsoft.VisualStudio.Services" }
    ],
    "icons": {
        "default": "img/logo.png"
    },
    "scopes": ["vso.work"],
    "contributions": [
        {
            "id": "AccessEpicsWidget",
            "type": "ms.vss-dashboards-web.widget",
            "targets": ["ms.vss-dashboards-web.widget-catalog"],
            "properties": {
                "name": "Access Epics",
                "description": "A widget to know how are the epics in a project",
                "catalogIconUrl": "img/catalogIcon.png",
                "previewImageUrl": "img/preview.png",
                "uri": "hello-world.html",
                "isNameConfigurable": true,
                "supportedSizes": [{ "rowSpan": 1, "columnSpan": 2 }],
                "supportedScopes": ["project_team"],
                "configurationContributionId": "DiegoNttdata.azure-devops-extensions-accessEpics.AccessEpicsWidget.configuration"
            }
        },
        {
            "id": "AccessEpicsWidget.configuration",
            "type": "ms.vss-dashboards-web.widget-configuration",
            "targets": ["ms.vss-dashboards-web.widget-configuration"],
            "properties": {
                "name": "Configuración",
                "uri": "configuration.html"
            }
        }
    ],
    "files": [
        { "path": "hello-world.html", "addressable": true },
        { "path": "configuration.html", "addressable": true },
        { "path": "scripts", "addressable": true },
        { "path": "sdk/scripts", "addressable": true },
        { "path": "img", "addressable": true }
    ]
}